# BEGIN_KITTY_THEME
# Rosé Pine
include current-theme.conf
# END_KITTY_THEME

window_padding_width 15 15 0 15
window_margin_width 0
modify_font cell_height 125%
font_size 12
background_opacity 0.88
# background_opacity 1

#background_opacity 0.9
# Fonts
# Nerd Fonts v3.1.0
font_family         JetBrainsMonoNL
bold_font           JetBrainsMonoNLExtraBold
bold_italic_font    JetBrainsMonoNLExtraBoldItalic

# Mapping
map ctrl+shift+0 change_font_size all 12.0
